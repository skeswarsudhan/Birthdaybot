# =============================================================================
# Birthday Bot — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — the bot will not start without these
# -----------------------------------------------------------------------------

# Groq API key — free at https://console.groq.com
# Supports Llama 3.3 70B, Llama 3 70B, Mixtral and more — 14,400 req/day free
GROQ_API_KEY=

# SendGrid API key — free at https://app.sendgrid.com/settings/api_keys
# Free tier: 100 emails/day forever. Works on Render/Railway/any cloud host.
SENDGRID_API_KEY=

# The "from" address for all outgoing emails.
# IMPORTANT: This address must be verified as a Single Sender in SendGrid.
# See: https://app.sendgrid.com/settings/sender_auth/senders
FROM_EMAIL=you@yourdomain.com

# Display name that appears in the "From" field of every email
FROM_NAME=Birthday Bot

# Admin email — receives daily digest reports
ADMIN_EMAIL=admin@yourdomain.com

# -----------------------------------------------------------------------------
# OPTIONAL — sensible defaults are shown
# -----------------------------------------------------------------------------

# Base URL of this application.
#   Local development: http://localhost:8080
#   Render:            https://your-app-name.onrender.com
BASE_URL=http://localhost:8080

# Port to run the web server on (must match BASE_URL port if using localhost)
PORT=8080

# Number of days before a birthday to send the manager request email
DAYS_BEFORE=7

# Maximum number of reminder emails to send if the manager doesn't respond
MAX_REMINDERS=2

# Path to the employee Excel file (relative to the project root)
EXCEL_PATH=employees.xlsx

# Data source: 'excel' (default) or 'sharepoint' (stub — raises error)
DATA_SOURCE=excel

# Directory where uploaded manager photos are stored
UPLOAD_DIR=uploads/

# Email domain used to construct employee emails from Ent ID
# Example: if Ent ID is "jsmith", email = jsmith@accenture.com
COMPANY_DOMAIN=accenture.com

# Timezone for all scheduler jobs (must be a valid pytz timezone string)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
SCHEDULER_TIMEZONE=Asia/Kolkata
